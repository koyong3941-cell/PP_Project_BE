<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.pp.board.model.dao.AdminCategoryMapper">

<!-- Create -->
	<insert id="saveCategory">
		INSERT
		  INTO
		  		CATEGORY
		  		(
					CATEGORY_NAME
				)
		VALUES
				(
					#{categoryName}
				)
	</insert>
	
<!-- Read -->
	<select id="findCategoryAll">
		SELECT
				CATEGORY_NO
			 ,	CATEGORY_NAME
		  FROM
		  		CATEGORY
		 ORDER
		 	BY
		 		CATEGORY_NO DESC
		OFFSET
				#{offset} ROWS FETCH
		  NEXT
		  		#{size} ROWS ONLY
	</select>
	
	<select id="findCategoryByKeyword">
		SELECT
				CATEGORY_NO
			 ,	CATEGORY_NAME
		  FROM
		  		CATEGORY
		 WHERE
		 		<foreach collection="keywordList" item="word" separator="AND">
					CATEGORY_NAME LIKE '%' || #{word} || '%'
				</foreach>
		 ORDER
		 	BY
		 		CATEGORY_NO DESC
		OFFSET
				#{offset} ROWS FETCH
		  NEXT
		  		#{size} ROWS ONLY
	</select>
	
<!-- Delete -->
	<delete id="deleteCategory">
   		DELETE
   		  FROM
   				CATEGORY
   		 WHERE
   				CATEGORY_NO IN
   				<foreach item="categoryNo" collection="categoryNos" 
             			 open="(" separator="," close=")">
       			 	#{categoryNo}
    			</foreach>
	</delete>

	
<!-- Count -->
	<select id="getCategoryTotalElements">
		SELECT
				COUNT(*)
		  FROM
		  		CATEGORY
	</select>

	<select id="getCategoryTotalElementsByKeyword">
		SELECT
				COUNT(*)
		  FROM
		  		CATEGORY
		 WHERE
		 		<foreach collection="keywordList" item="word" separator="AND">
					CATEGORY_NAME LIKE '%' || #{word} || '%'
				</foreach>
	</select>
	
</mapper>